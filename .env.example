# ============ LLM ============
# OpenAI 兼容协议。默认 DeepSeek（国内可直连、便宜）
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-your-deepseek-key
LLM_MODEL=deepseek-chat

# ============ STT (语音转文字) ============
# 可选: local_whisper | volcengine_asr | openai_compat
#
# - local_whisper: 本地 faster-whisper，零门槛，默认推荐
# - volcengine_asr: 火山引擎豆包流式语音识别 2.0，中文准确率更高，且支持
#   边说边出字的实时字幕（前端发送 16kHz PCM，后端 WebSocket 转发）。
#   开通地址: https://console.volcengine.com/speech/service/10007
#   新版控制台用 API Key（下方 VOLCENGINE_ASR_API_KEY）；试用 20 小时，
#   资源包 900 元起（按小时用量计费）
# - openai_compat: 使用 OPENAI_* 那套 endpoint 的 Whisper API
STT_PROVIDER=local_whisper
# 本地 whisper 模型: tiny | base | small | medium | large-v3
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# 火山引擎 ASR API Key（STT_PROVIDER=volcengine_asr 时才需要填）
# 新版控制台「API Key 管理」创建；旧版控制台可改用 DOUBAO_APP_ID + DOUBAO_ACCESS_TOKEN
VOLCENGINE_ASR_API_KEY=

# ============ TTS (文字转语音) ============
# 可选: edge | openai_compat | doubao
#
# - edge: 免费的微软 Edge TTS，零门槛，中文音色可用，默认推荐
# - doubao: 火山引擎豆包语音合成大模型，中文更自然、更有情感（付费，
#   ~¥15/百万字符，一场面试约 ¥0.05），需要在火山引擎后台开通"语音合成大模型"
#   服务后填下面 4 个 DOUBAO_* 字段
# - openai_compat: 使用 OPENAI_* 那套 endpoint 的 TTS 接口
TTS_PROVIDER=edge
# edge-tts 中文音色: zh-CN-XiaoxiaoNeural / zh-CN-YunjianNeural / zh-CN-YunxiNeural
TTS_VOICE=zh-CN-YunjianNeural

# 豆包 TTS 凭证（TTS_PROVIDER=doubao 时才需要填）
# 开通指南: https://www.volcengine.com/docs/6561/1257544
DOUBAO_APP_ID=
DOUBAO_ACCESS_TOKEN=
DOUBAO_CLUSTER=volcano_tts
# 音色列表: https://www.volcengine.com/docs/6561/162929
# 默认"云舟" (Seed TTS 2.0 沉稳男声)，其他 2.0 音色推荐:
#   zh_male_m191_uranus_bigtts    (云舟 — 沉稳男声，默认)
#   zh_female_xiaohe_uranus_bigtts (小何 — 自然女声)
#   zh_male_taocheng_uranus_bigtts (小天 — 年轻男声)
DOUBAO_VOICE_TYPE=zh_male_m191_uranus_bigtts

# ============ 数据库 ============
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=offer
MYSQL_PASSWORD=offer_pass
MYSQL_DATABASE=offer_master
MYSQL_ROOT_PASSWORD=root_pass

# ============ 面试策略 ============
# 每轮最少/最多主题问题数
QUESTIONS_PER_ROUND_MIN=5
QUESTIONS_PER_ROUND_MAX=8
# 同一主题最大追问次数
MAX_FOLLOWUPS=2
# 追问激进度: aggressive | balanced | lenient
FOLLOWUP_STRATEGY=balanced
# 每轮通过总分阈值 (0-100)
ROUND_PASS_THRESHOLD=70

# ============ 存储 ============
STORAGE_DIR=/data
